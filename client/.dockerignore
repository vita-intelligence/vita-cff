# Version control
.git
.gitignore
.gitattributes

# Dependencies (will be reinstalled inside the image)
node_modules

# Build artifacts (regenerated by ``next build``)
.next
out
dist

# Environment files (build args / runtime env handle these)
.env
.env.*
!.env.example

# Editor / OS
.vscode
.idea
.DS_Store
*.swp
*.swo

# Logs and caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.cache
coverage
.tsbuildinfo
tsconfig.tsbuildinfo

# Docker recursion guard
Dockerfile
Dockerfile.*
.dockerignore
docker-compose*.yml
