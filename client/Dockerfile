# ============================================================
# Stage 1 — install full deps (used by the build stage)
# ============================================================
FROM node:20-alpine AS deps
WORKDIR /app

# Copy only the manifests so this layer caches across code-only edits
COPY package.json package-lock.json ./
RUN npm ci --no-audit --no-fund

# ============================================================
# Stage 2 — build the Next.js app
# ============================================================
FROM node:20-alpine AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# NEXT_PUBLIC_* values are inlined into the JavaScript bundle at
# ``next build`` time, so they MUST be present as build args. Pass
# them on the docker build command line via --build-arg.
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_WS_ORIGIN
ARG BACKEND_INTERNAL_URL

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_WS_ORIGIN=$NEXT_PUBLIC_WS_ORIGIN
# next.config.ts captures BACKEND_INTERNAL_URL at build time (rewrites
# are baked into the standalone server bundle), so the URL must be
# present as a build arg — setting it as a runtime env var on App
# Service has no effect for the rewrite destination.
ENV BACKEND_INTERNAL_URL=$BACKEND_INTERNAL_URL
ENV NEXT_TELEMETRY_DISABLED=1

# Next expects a ``public/`` folder at the project root. Some apps
# don't have one yet — create an empty placeholder so the runtime
# COPY below always has a source.
RUN mkdir -p public

RUN npm run build

# ============================================================
# Stage 3 — slim runtime image
# ============================================================
FROM node:20-alpine AS runtime
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Non-root user. ``standalone`` output ships its own server.js plus a
# pruned ``node_modules`` tree — the image is otherwise read-only.
RUN addgroup -g 1001 -S nodejs \
    && adduser -u 1001 -S nextjs -G nodejs

COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

USER nextjs

EXPOSE 3000

# server.js is generated by ``next build`` when ``output: "standalone"``
CMD ["node", "server.js"]
