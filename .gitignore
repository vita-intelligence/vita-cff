# ---------------------------------------------------------------------------
# Vita NPD — repository .gitignore
# Covers: Python / Django backend, Node / Next.js frontend, tooling, IDEs, OS.
# Keep this file authoritative — do not add per-app .gitignore files unless
# strictly necessary.
# ---------------------------------------------------------------------------

# ----- Internal-only files (never commit) ----------------------------------
CLAUDE.md
AGENTS.md
.claude/

# ----- Secrets & environment ------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.crt
secrets/
credentials/

# ----- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
wheels/
pip-wheel-metadata/
.installed.cfg
MANIFEST

# ----- Virtual environments -------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# ----- Django ---------------------------------------------------------------
*.sqlite3
*.sqlite3-journal
db.sqlite3
db.sqlite3-journal
