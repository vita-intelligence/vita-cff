# =============================================================
# Vita NPD backend — environment variables
# =============================================================
# Copy this file to `.env` for local overrides, or paste these
# keys into Azure App Service → Configuration → Application
# settings for production. Values shown here are PLACEHOLDERS.
# =============================================================

# ---------- Django core ----------
# Must be False in production. Setting it to True exposes stack
# traces and DB queries in error responses.
DJANGO_DEBUG=False

# Required when DJANGO_DEBUG=False. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# Comma-separated. Must include the App Service hostname AND any
# custom domain you point at it.
DJANGO_ALLOWED_HOSTS=vita-npd-backend-d6gkh9ehf8cwftfq.westeurope-01.azurewebsites.net

# Comma-separated origins (with scheme). The Next.js client URL
# goes here so POST/PUT/DELETE requests pass CSRF.
DJANGO_CSRF_TRUSTED_ORIGINS=https://vita-npd-frontend.azurewebsites.net,https://vita-npd-backend.azurewebsites.net

# CORS origins — same idea, must match the Next.js URL exactly.
DJANGO_CORS_ALLOWED_ORIGINS=https://vita-npd-frontend.azurewebsites.net

# ---------- TLS / proxy ----------
# Azure App Service terminates TLS upstream and forwards HTTP to
# the container with X-Forwarded-Proto=https. Turn these on in prod.
DJANGO_USE_X_FORWARDED_PROTO=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False

# ---------- Auth cookies ----------
# Leave AUTH_COOKIE_DOMAIN unset unless the API and frontend share
# a parent domain (e.g. .vita-npd.com) and need a shared cookie.
# AUTH_COOKIE_DOMAIN=.vita-npd.com
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=Lax

# ---------- Database ----------
# Azure Database for PostgreSQL Flexible Server connection string.
# Format: postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=postgres://vitaadmin:CHANGE-ME@vita-npd-db.postgres.database.azure.com:5432/postgres?sslmode=require
DATABASE_SSL_REQUIRE=True

# ---------- Azure Blob storage (media) ----------
# Found under Storage Account → Access keys in the portal.
AZURE_STORAGE_ACCOUNT_NAME=vitanpdstorage
AZURE_STORAGE_ACCOUNT_KEY=CHANGE-ME
AZURE_STORAGE_MEDIA_CONTAINER=media

# ---------- App identity ----------
# The frontend origin — used to build links inside notification
# emails (password reset, approval requests, etc.).
APP_BASE_URL=https://vita-npd-frontend.azurewebsites.net

# ---------- Email ----------
# Production should point at a real SMTP relay (SendGrid, Azure
# Communication Services, etc.). Console backend is for dev only.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=CHANGE-ME
DEFAULT_FROM_EMAIL=Vita NPD <no-reply@vita-npd.com>

# ---------- Channels (WebSockets) ----------
# Optional. Leave unset to use the in-memory channel layer (single
# container, fine for internal use). Point at an Azure Cache for
# Redis instance if you scale beyond one replica.
# CHANNEL_LAYER_URL=rediss://:KEY@vita-npd-redis.redis.cache.windows.net:6380/0

# ---------- AI provider ----------
# Default Ollama path is for local dev. In production, leave unset
# until a managed provider adapter is wired up.
# AI_OLLAMA_URL=http://127.0.0.1:11434
# AI_OLLAMA_MODEL=llama3.2:3b
AI_PROVIDER_TIMEOUT_SECONDS=120
